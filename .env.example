# Famile agent — LLM providers (server-only; never NEXT_PUBLIC_*)
#
# Default failover order: Venice → 0G Router → Anthropic → recorded replay.
# Override with: LLM_PROVIDER_ORDER=venice,og,anthropic

# Venice AI (OpenAI-compatible)
# https://docs.venice.ai/
VENICE_API_KEY=
# VENICE_BASE_URL=https://api.venice.ai/api/v1
# VENICE_MODEL=zai-org-glm-5-1

# 0G Compute Router (OpenAI-compatible)
# https://docs.0g.ai/developer-hub/building-on-0g/compute-network/inference
# API key from https://pc.0g.ai (sk-…)
OG_API_KEY=
# OG_BASE_URL=https://router-api.0g.ai/v1
# OG_MODEL=zai-org/GLM-5-FP8

# Anthropic (optional fallback)
# LLM_API_KEY=
# ANTHROPIC_API_KEY=
# LLM_MODEL=claude-3-5-sonnet-latest

# LLM_PROVIDER_ORDER=venice,og,anthropic
